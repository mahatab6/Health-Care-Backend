model DocumentEmbedding {
    id String @id @default(uuid(7))

    chunkKey    String  @unique
    sourceType  String
    sourceId    String
    sourceLabel String?
    content     String
    metadata    Json?

    embedding Unsupported("vector(1536)")

    isDeleted Boolean   @default(false)
    deletedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([sourceType], name: "idx_DocumentEmbedding_SourceType")
    @@index([sourceId], name: "idx_DocumentEmbedding_SourceId")
    @@map("DocumentEmbedding")
}
